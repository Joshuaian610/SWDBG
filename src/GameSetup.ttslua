        getObjectbyName("Zone Faction Select Bottom"),
        getObjectbyName("Button Play Empire Bottom"),
        getObjectbyName("Button Play Rebellion Bottom"),
        getObjectbyName("Button Play Separatist Bottom"),
        getObjectbyName("Button Play Republic Bottom"),
        getObjectbyName("Button Play Mandalorian Bottom"),
        getObjectbyName("Button Play Random Bottom"),
      },
      Top = {
        getObjectbyName("Setup Backdrop Top"),
        getObjectbyName("Zone Faction Select Top"),
        getObjectbyName("Button Play Empire Top"),
        getObjectbyName("Button Play Rebellion Top"),
        getObjectbyName("Button Play Separatist Top"),
        getObjectbyName("Button Play Republic Top"),
        getObjectbyName("Button Play Mandalorian Top"),
        getObjectbyName("Button Play Random Top"),
      }
    }
  }
  -- handles setup of player area upon faction selection

  local buttonName = button.getName()
  -- buttonName will be in format: "Button Play " .. <factionName> .. " " .. <area>
  -- using regex, I need to get factionName and area
  local factionName, playerArea = string.match(buttonName, "Button Play (%w+) (%w+)")

  -- handle random into a different available
  if factionName == "Random" then
    local setupButtons = {}
    for _, zoneObj in pairs(zoneFactionSelectBottom.getObjects()) do
      if zoneObj.getName():find("Button Play") and zoneObj ~= button then
        table.insert(setupButtons, zoneObj)
      end
    end
    local randomButton = setupButtons[math.random(1, #setupButtons)]
    factionName, _ = string.match(randomButton.getName(), "Button Play (%w+) (%w+)")
  end

  local factionColor = factionVars[factionName].factionColor

  -- pull image info from backdrop, define image vars
  local uiObjImages = imageVars[factionName]
  
  for i = 1, 9 do
    -- change images, color tint on UI area assets    
    if i ~= 9 then
      playerAreaObjs["playerUI"][playerArea][i].setCustomObject({
        image = uiObjImages[i],
        imageBottom = uiObjImages[i],
      })
    end
    playerAreaObjs["playerUI"][playerArea][i].setColorTint(factionColor)
    playerAreaObjs["playerUI"][playerArea][i] = playerAreaObjs["playerUI"][playerArea][i].reload()

    -- rename player area objs that require a rename
    local objNames = {
      "Pad Discard " .. factionName,
      "Pad Deck " .. factionName,
      "Button Discard " .. factionName,
      "Pad Bases " .. factionName,
      "Damage Counter " .. factionName,
    }
    local objName = nil
    if i < 6 then
      objName = objNames[i]
      playerAreaObjs["playerUI"][playerArea][i].setName(objName)
    end

    playerAreaObjs["playerUI"][playerArea][i].tooltip = false
    if i == 9 then
      playerAreaObjs["playerUI"][playerArea][9].tooltip = true
    end
  end

  -- set end turn button invis by default (setupGame() will show correct button)
  playerAreaObjs["playerUI"][playerArea][8].setInvisibleTo(allColors)

  -- change color on counter
  playerAreaObjs["playerUI"][playerArea][5].clearButtons()
  local buttonColor = factionVars[factionName].buttonColor
  local hoverColor = factionVars[factionName].hoverColor
  playerAreaObjs["playerUI"][playerArea][5].call('createAll', buttonColor, hoverColor)

  -- change counter bag to faction
  local counterBag = playerArea == "Bottom" and getObjectbyName("Counter Bag Bottom") or getObjectbyName("Counter Bag Top")
  local bagStates = {
    ["Empire"]      = 2,
    ["Separatist"]  = 3,
    ["Rebellion"]   = 4,
    ["Republic"]    = 5,
    ["Mandalorian"] = 6
  }  
  counterBag.setState(bagStates[factionName])

  -- place decks
  local playerAreaVars = {
    Bottom             = {
      rotStarter       = { 0.00, 180.00, 180.00 },
      posStarter       = { -3.50, 1.00, -31.00 },
      rotBase          = { 0.00, 180.00, 180.00 },
      posBase          = { 8.00, 0.44, -31.00 },
      rotInitial       = { 0.00, 180.00, 0.00 },
      posInitial       = { 8.00, 3.00, -31.00 },
    },
    Top                = {
      rotStarter       = { 0.00, 0.00, 180.00 },
      posStarter       = { 3.50, 1.00, 31.00 },
      rotBase          = { 0.00, 0.00, 180.00 },
      posBase          = { -8.00, 0.45, 31.00 },
      rotInitial       = { 0.00, 0.00, 0.00 },
      posInitial       = { -8.00, 3.00, 31.00 },
    },
  }

  
  local rotStarter = playerAreaVars[playerArea].rotStarter
  local posStarter = playerAreaVars[playerArea].posStarter
  local rotBase = playerAreaVars[playerArea].rotBase
  local posBase = playerAreaVars[playerArea].posBase
  local rotInitial = playerAreaVars[playerArea].rotInitial
  local posInitial = playerAreaVars[playerArea].posInitial
  local deckStarter = factionVars[factionName].deckStarter
  local rotGalaxyDeck = { 0.00, 90.00, 180.00 }
  local posGalaxyDeck = { -28.00, 0.91, 2.50 }
  local posShipGalaxyDeck = { -28.00, 0.91, 2.50 }

  -- place starter deck
  deckStarter.setLock(false)
  deckStarter.setRotation(rotStarter)
  deckStarter.setPositionSmooth(posStarter)

  -- bases (needs to pull and place initial base)
  local initialBaseName = factionVars[factionName].firstBase
  local deckBases = factionVars[factionName].deckBases
  local deckBasesObjs = deckBases.getObjects()
  local initialBase = nil
  for _, deckObj in ipairs(deckBasesObjs) do
    if deckObj.name == initialBaseName then
      initialBase = deckBases.takeObject({guid=deckObj.guid})
    end
  end
  if initialBase == nil then log("Starter Base not found in deck!!") return end

  deckBases.setLock(true)
  Wait.time(function() deckBases.setLock(false) end, 2)

  deckBases.setRotation(rotBase)
  deckBases.setPosition(posBase)
  initialBase.setRotation(rotInitial)
  initialBase.setPosition(posInitial)

  -- place faction's galaxy deck
  local deckGalaxy = factionVars[factionName].deckGalaxy
  deckGalaxy.setLock(false)
  deckGalaxy.setRotation(rotGalaxyDeck)
  deckGalaxy.setPosition(posGalaxyDeck)

  -- place faction's ships deck
  local deckShips = factionVars[factionName].deckShips
  deckShips.setLock(false)
  deckShips.setRotation(rotGalaxyDeck)
  deckShips.setPosition(posShipGalaxyDeck)

  -- destroy player area setup backdrop and buttons
  for i = 1, 8 do
    if playerAreaObjs["destroyObjs"][playerArea][i] ~= nil then
      playerAreaObjs["destroyObjs"][playerArea][i].destruct()
    end
  end

  -- destroy counterpart button in other player area
  local oppositeArea = playerArea == "Bottom" and "Top" or "Bottom"
  if getObjectbyName("Button Play " .. factionName .. " " .. oppositeArea) ~= nil then
    getObjectbyName("Button Play " .. factionName .. " " .. oppositeArea).destruct()
  end

  -- destroy card back buttons ** IS THIS NEEDED
  for _, obj in pairs(getObjects()) do
    if obj.hasTag('buttons_cardback') then
      obj.destruct()
    end
  end

  -- mark object for detection functions
  -- bottom, so, uses stormtrooper helmet
  local artAsset = playerArea == "Bottom" and artAssetBottom or artAssetTop
  artAsset.setGMNotes(factionName)

  -- broadcast
  local currentHandColor = playerArea == "Bottom" and zoneHandzoneBottom.getData()["FogColor"] or zoneHandzoneTop.getData()["FogColor"]
  if Player[currentHandColor].steam_name ~= nil then
    broadcastToAll("[" .. Color.fromString(currentHandColor):toHex() .. "]" .. Player[currentHandColor].steam_name .. "[-] will play as [" .. Color.fromString(factionColor):toHex() .. "]" .. factionName .. ".", "White")
  else
    broadcastToAll("[" .. Color.fromString(currentHandColor):toHex() .. "]" .. currentHandColor .. " Player[-] will play as [" .. Color.fromString(factionColor):toHex() .. "]" .. factionName .. ".", "White")
  end
end -- end setupFaction()
-- NEEDS SETUP OF GENERIC COUNTER BAGS (remember to set .y to .20)



-- GAME SETUP

function setupGame(button, _, _)
  local isAI = getObjectbyName("Button Enable Leaders").getGMNotes() == "enabled" and true or false

  -- check that both player areas have selected a faction
  if getObjectbyName("Setup Backdrop Bottom") or getObjectbyName("Setup Backdrop Top") then -- check for backdrop objects
    broadcastToAll("Both players must select a faction before setup can continue.", "Yellow")
    return
  end

  -- check that a galaxy deck type is enabled
  if getObjectbyName("Button Galaxy Deck Original").getGMNotes() == "disabled" and
  getObjectbyName("Button Galaxy Deck Random").getGMNotes() == "disabled" and
  getObjectbyName("Button Galaxy Deck Expansion").getGMNotes() == "disabled" then
    broadcastToAll("A galaxy deck option must be selected before setup can continue.", "Yellow")
    return
  end

  -- get factions, locations (check zones for starter deck tags)
  local bottomFaction, topFaction = getPlayerAreas()

  -- set player seat colors
  ---- empire/separatist blue, or separatist purple if both are in
  ---- rebel/republic red, or republic orange if both are in  
  local currentPlayers = getSeatedPlayers()
  local playerBottom = nil
  local playerTop = nil

  if currentPlayers[1] then
    playerBottom = Player[currentPlayers[1]]
  end
  if currentPlayers[2] then
    playerTop = Player[currentPlayers[2]]
  end

  -- need to set CW factions to their backup color if primary color is already taken
  local baseColors = {
    Separatist     = "Blue",
    Empire         = "Blue",
    Republic       = "Red",
    Rebellion      = "Red",
    Mandalorian    = "Green",
  }
  local overrideRules = {
    Republic          = {
      requiredFaction = "Rebellion",
      overrideColor   = "Orange",
    },
    Separatist        = {
      requiredFaction = "Empire",
      overrideColor   = "Purple",
    }
  }
  local factionsInGame = {
    [bottomFaction]    = true,
    [topFaction]       = true,
  }

  local bottomColor = baseColors[bottomFaction]
  local topColor    = baseColors[topFaction]

  -- apply override for bottom faction
  local rule = overrideRules[bottomFaction]
  if rule and factionsInGame[rule.requiredFaction] then
    bottomColor = rule.overrideColor
  end

  -- apply override for top faction
  rule = overrideRules[topFaction]
  if rule and factionsInGame[rule.requiredFaction] then
    topColor = rule.overrideColor
  end

  -- set string for getPlayerColors()
  artAssetBottom.setDescription(bottomColor)
  artAssetTop.setDescription(topColor)

  -- change hand zone colors
  if zoneHandzoneBottom.getValue() ~= bottomColor then
    zoneHandzoneBottom.setValue(bottomColor)
  end
  if zoneHandzoneTop.getValue() ~= topColor then
    zoneHandzoneTop.setValue(topColor)
  end

  -- deploy republic reveal pad stuff
  if bottomFaction == "Republic" then
    setupRevealUI("Bottom")
  elseif topFaction == "Republic" then
    setupRevealUI("Top")
  end
  hideRevealUI()

  -- set players to new hand zones, tint player area assets
  local tintObjBottom = {
    getObjectbyName("Pad Discard " .. bottomFaction),
    getObjectbyName("Pad Deck " .. bottomFaction),
    getObjectbyName("Button Discard " .. bottomFaction),
    getObjectbyName("Pad Bases " .. bottomFaction),
    getObjectbyName("Damage Counter " .. bottomFaction),
    getObjectbyName("Pad Victory Pile Bottom"),
    getObjectbyName("Button Force Bottom"),
    getObjectbyName("Button End Turn Bottom"),
    getObjectbyNameAndNotes("Exiled!", "Bottom")
  }
  local tintObjTop = {
    getObjectbyName("Pad Discard " .. topFaction),
    getObjectbyName("Pad Deck " .. topFaction),
    getObjectbyName("Button Discard " .. topFaction),
    getObjectbyName("Pad Bases " .. topFaction),
    getObjectbyName("Damage Counter " .. topFaction),
    getObjectbyName("Damage Counter " .. topFaction),
    getObjectbyName("Pad Victory Pile Top"),
    getObjectbyName("Button Force Top"),
    getObjectbyName("Button End Turn Top"),
    getObjectbyNameAndNotes("Exiled!", "Top")
  }
  Wait.frames(function()
    if playerBottom ~= nil then
      if playerBottom.color ~= bottomColor then
        playerBottom.changeColor(bottomColor)
      end
      for i = 1, 9 do
        tintObjBottom[i].setColorTint(bottomColor)
      end
    end
    if playerTop ~= nil then
      if playerTop.color ~= topColor then
        playerTop.changeColor(topColor)
      end
      for i = 1, 9 do
        tintObjTop[i].setColorTint(topColor)
      end
    end
  end, 2) -- was previously 2 frames, revert if issue comes up

  -- place selected galaxy deck, remove other
  local deckPlacementGalaxy = nil
  local deckPlacementShips = nil
  local deckRemovalGalaxy = nil
  local deckRemovalShips = nil
  local deckPlacementOuterRim = nil
  local deckRemovalOuterRim = nil
  local randomNumber = nil

  if getObjectbyName("Button Galaxy Deck Original").getGMNotes() == "enabled" then
    deckPlacementGalaxy = getObjectbyName("Original Neutral Units")
    deckPlacementShips = getObjectbyName("Original Neutral Ships")
    deckRemovalGalaxy = getObjectbyName("Clone Wars Neutral Units")
    deckRemovalShips = getObjectbyName("Clone Wars Neutral Ships")
    deckPlacementOuterRim = getObjectbyName("Original Outer Rim Pilot Deck")
    deckRemovalOuterRim = getObjectbyName("Clone Wars Outer Rim Pilot Deck")

  elseif getObjectbyName("Button Galaxy Deck Expansion").getGMNotes() == "enabled" then
    deckPlacementGalaxy = getObjectbyName("Clone Wars Neutral Units")
    deckPlacementShips = getObjectbyName("Clone Wars Neutral Ships")
    deckRemovalGalaxy = getObjectbyName("Original Neutral Units")
    deckRemovalShips = getObjectbyName("Original Neutral Ships")
    deckPlacementOuterRim = getObjectbyName("Clone Wars Outer Rim Pilot Deck")
    deckRemovalOuterRim = getObjectbyName("Original Outer Rim Pilot Deck")

  elseif getObjectbyName("Button Galaxy Deck Random").getGMNotes() == "enabled" then
    randomNumber = math.random(1, 2)
    if randomNumber == 1 then
      deckPlacementGalaxy = getObjectbyName("Original Neutral Units")
      deckPlacementShips = getObjectbyName("Original Neutral Ships")
      deckRemovalGalaxy = getObjectbyName("Clone Wars Neutral Units")
      deckRemovalShips = getObjectbyName("Clone Wars Neutral Ships")
      deckPlacementOuterRim = getObjectbyName("Original Outer Rim Pilot Deck")
      deckRemovalOuterRim = getObjectbyName("Clone Wars Outer Rim Pilot Deck")

    elseif randomNumber == 2 then
      deckPlacementGalaxy = getObjectbyName("Clone Wars Neutral Units")
      deckPlacementShips = getObjectbyName("Clone Wars Neutral Ships")
      deckRemovalGalaxy = getObjectbyName("Original Neutral Units")
      deckRemovalShips = getObjectbyName("Original Neutral Ships")
      deckPlacementOuterRim = getObjectbyName("Clone Wars Outer Rim Pilot Deck")
      deckRemovalOuterRim = getObjectbyName("Original Outer Rim Pilot Deck")
    end
  end

  local rotDecks = { 0.00, 90.00, 180.00 }
  local posDeckGalaxy = { -28.00, 0.91, 2.50 }
  local rotOuterRim = { 0.00, 270.00, 0.00 }
  local posOuterRim = { 21.00, 0.50, 0.00 }

  deckPlacementGalaxy.setRotation(rotDecks)
  deckPlacementGalaxy.setLock(false)
  deckPlacementGalaxy.setPositionSmooth(posDeckGalaxy, false, true)

  deckPlacementShips.setRotation(rotDecks)
  deckPlacementShips.setLock(false)
  deckPlacementShips.setPositionSmooth(posDeckGalaxy, false, true)
  deckPlacementOuterRim.setRotation(rotOuterRim)
  deckPlacementOuterRim.setLock(false)
  deckPlacementOuterRim.setPositionSmooth(posOuterRim, false, true)
    
  artAssetTop.putObject(deckRemovalGalaxy) -- artAssetTop bag used as unusedObjs bag
  artAssetTop.putObject(deckRemovalShips)
  artAssetTop.putObject(deckRemovalOuterRim)

  -- shuffle galaxy deck, deal galaxy row
  Wait.time(function()

    local deckGalaxy = getGalaxyDeck()
    if deckGalaxy then
      deckGalaxy.setName('Galaxy Deck')
      deckGalaxy.shuffle()
    end
    local posDeal = {
      { -21.00, 0.75, 0.00 },
      { -14.00, 0.75, 0.00 },
      { -7.00, 0.75, 0.00 },
      { 0.00, 0.75, 0.00 },
      { 7.00, 0.75, 0.00 },
      { 14.00, 0.75, 0.00 }
    }
    for i = 1, 6 do
      local card = deckGalaxy.takeObject()      
      Wait.frames(function() rotateDealtCard(card, posDeal[i]) end)
    end

    -- show previously invis purchase/discard buttons
    for _, object in ipairs(getObjects()) do
      if object.hasTag('row_button') then
        object.setInvisibleTo({})
      end
    end

  end, 1)

  -- clean up unselected faction decks, shuffle starters in play  
  local factions = getFactions()
  local function checkIfInGalaxyDeckSlot(deck)
    -- simply check if the object is in the galaxy deck zone, return boolean
    inGalaxyDeckSlot = false
    for _, zoneObj in pairs(zoneGalaxyDeck.getObjects()) do
      if zoneObj == deck then inGalaxyDeckSlot = true end
    end
    return inGalaxyDeckSlot
  end
  -- empire
  if not factions[1] then    
    for _, object in ipairs(getObjects()) do
      if object.hasTag('empire') and not checkIfInGalaxyDeckSlot(object) then
        artAssetTop.putObject(object)
      end
    end
  else
    getObjectbyName("Empire Deck").shuffle()
  end

  -- separatist
  if not factions[4] then
    for _, object in ipairs(getObjects()) do
      if object.hasTag('Separatist') and not checkIfInGalaxyDeckSlot(object) then
        artAssetTop.putObject(object)
      end
    end
  else
    getObjectbyName("Separatist Deck").shuffle()
  end

  -- Republic
  if not factions[2] then
    for _, object in ipairs(getObjects()) do
      if object.hasTag('Republic') and not checkIfInGalaxyDeckSlot(object) then
        artAssetTop.putObject(object)
      end
    end
  else
    getObjectbyName("Republic Deck").shuffle()
  end

  -- rebellion
  if not factions[3] then
    for _, object in ipairs(getObjects()) do
      if object.hasTag('rebel') and not checkIfInGalaxyDeckSlot(object) then
        artAssetTop.putObject(object)
      end
    end
  else
    getObjectbyName("Rebellion Deck").shuffle()
  end

  -- mandalorian
  if not factions[5] then
    for _, object in ipairs(getObjects()) do
      if object.hasTag('mandalorian') and not checkIfInGalaxyDeckSlot(object) then
        artAssetTop.putObject(object)
      end
    end
  else
    getObjectbyName("Mandalorian Deck").shuffle()
  end

  -- shuffle, deal to hand
  dealCard("bottom", 5)
  if not isAI then
    dealCard("top", 5)
  end
  
  -- determine first player
  -- enable turns, set turn to first player
  local randomFirstPlayer = math.random(2)
  local trackerForce = getObjectbyName("Force Tracker")
  local forceTrack = getObjectbyName("Force Track")
  local rotTracker = nil
  local posTracker = nil
  local trackerColor = nil
  local turnTracker = getTurnTracker()

  -- check if start randomization required
  local requireRandom = true
  if (bottomFaction == "Empire" and topFaction == "Rebellion") or
  (bottomFaction == "Separatist" and topFaction == "Republic") then

    requireRandom = false
    
    -- bottom first player set turn
    Wait.frames(function()
      if Turns.enable then Turns.turn_color = bottomColor end
    end, 5) -- was 5 frames, if issue, revert

    rotTracker = { 0, 180, 0 }
    posTracker = { -46.00, 0.12, -21.00 }
    if bottomFaction == "Separatist" then
      turnTracker = turnTracker.setState(2)
    end
    trackerColor = bottomColor
    counterResourceBoardBottom.setInvisibleTo({})
    counterResourceBoardTop.setInvisibleTo(allColors)
    
    getObjectbyName("Button End Turn Bottom").setInvisibleTo({})
    getObjectbyName("Button End Turn Top").setInvisibleTo(allColors)

    -- top second player set force track
    trackerForce.setColorTint(topColor)
    trackerForce.highlightOn(topColor)
    forceTrack.setColorTint(topColor)

    broadcastToAll("The force is with [" .. Color.fromString(topColor):toHex() .. "]" .. topFaction .. "[-].", "White")
    broadcastToAll("[" .. Color.fromString(bottomColor):toHex() .. "]" .. bottomFaction .. "[-] gets first turn.", "White")

  elseif (bottomFaction == "Rebellion" and topFaction == "Empire") or
  (bottomFaction == "Republic" and topFaction == "Separatist") then
    
    requireRandom = false

    -- bottom second player set force track
    posTracker = { 29.41, 1.15, -8.50 }
    trackerForce.setColorTint(bottomColor)
    trackerForce.highlightOn(bottomColor)
    trackerForce.setPosition(posTracker)
    forceTrack.setColorTint(bottomColor)

    -- top first player set turn
    Wait.frames(function()
      if Turns.enable then Turns.turn_color = topColor end
    end, 5) -- was 5 frames, if issue, revert

    if not isAI then
      rotTracker = { 0, 0, 0 }
    elseif isAI then
      rotTracker = { 0, 180, 0 }
    end
    posTracker = { 46.00, 0.12, 21.00 }
    if topFaction ~= "Empire" then
      turnTracker = turnTracker.setState(2)
    end
    trackerColor = topColor
    counterResourceBoardTop.setInvisibleTo({})
    counterResourceBoardBottom.setInvisibleTo(allColors)

    getObjectbyName("Button End Turn Top").setInvisibleTo({})
    getObjectbyName("Button End Turn Bottom").setInvisibleTo(allColors)

    broadcastToAll("The force is with [" .. Color.fromString(topColor):toHex() .. "]" .. topFaction .. "[-].", "White")
    broadcastToAll("[" .. Color.fromString(bottomColor):toHex() .. "]" .. bottomFaction .. "[-] gets first turn.", "White")
  end

  if requireRandom then
    if randomFirstPlayer == 1 then
      -- bottom first player set turn
      Wait.frames(function()
        if Turns.enable then Turns.turn_color = bottomColor end
      end, 5) -- was 5 frames, if issue, revert

      rotTracker = { 0, 180, 0 }
      posTracker = { -46.00, 0.12, -21.00 }
      if bottomFaction == "Republic" then
        turnTracker = turnTracker.setState(4)
      elseif bottomFaction == "Rebellion" then
        turnTracker = turnTracker.setState(3)
      elseif bottomFaction == "Separatist" then
        turnTracker = turnTracker.setState(2)
      elseif bottomFaction == "Mandalorian" then
        turnTracker = turnTracker.setState(5)
      end
      trackerColor = bottomColor
      counterResourceBoardBottom.setInvisibleTo({})
      counterResourceBoardTop.setInvisibleTo(allColors)

      getObjectbyName("Button End Turn Bottom").setInvisibleTo({})
      getObjectbyName("Button End Turn Top").setInvisibleTo(allColors)

      -- top second player set force track      
      trackerForce.setColorTint(topColor)
      trackerForce.highlightOn(topColor)
      forceTrack.setColorTint(topColor)
      
      broadcastToAll("The force is with [" .. Color.fromString(topColor):toHex() .. "]" .. topFaction .. "[-].", "White")
      broadcastToAll("[" .. Color.fromString(bottomColor):toHex() .. "]" .. bottomFaction .. "[-] gets first turn.", "White")

    else
      -- bottom second player set force track
      posTracker = { 29.41, 1.15, -8.50 }
      trackerForce.setColorTint(bottomColor)
      trackerForce.highlightOn(bottomColor)
      trackerForce.setPosition(posTracker)
      forceTrack.setColorTint(bottomColor)

      -- top first player set turn
      Wait.frames(function()
        if Turns.enable then Turns.turn_color = topColor end
      end, 5)

      rotTracker = { 0, 0, 0 }
      posTracker = { 46.00, 0.12, 21.00 }
      if topFaction == "Republic" then
        turnTracker = turnTracker.setState(4)
      elseif topFaction == "Rebellion" then
        turnTracker = turnTracker.setState(3)
      elseif topFaction == "Separatist" then
        turnTracker = turnTracker.setState(2)
      elseif topFaction == "Mandalorian" then
        turnTracker = turnTracker.setState(5)
      end
      trackerColor = topColor
      counterResourceBoardTop.setInvisibleTo({})
      counterResourceBoardBottom.setInvisibleTo(allColors)
      
      getObjectbyName("Button End Turn Top").setInvisibleTo({})
      getObjectbyName("Button End Turn Bottom").setInvisibleTo(allColors)
      
      broadcastToAll("The force is with [" .. Color.fromString(bottomColor):toHex() .. "]" .. bottomFaction .. "[-].", "White")
      broadcastToAll("[" .. Color.fromString(topColor):toHex() .. "]" .. topFaction .. "[-] gets first turn.", "White")
    end
  end

  -- handle force track graphic in case of traditional matchup
  local forceTrackOriginal  = "https://steamusercontent-a.akamaihd.net/ugc/2478760129065188393/F54092F923F8BA59AC13E93874F92CE5C62DDC4B/"
  local forceTrackExpansion = "https://steamusercontent-a.akamaihd.net/ugc/2478760129065207212/5A5DF1FB7E5B591D9C33802D41319952F89E9CB9/"
  if topFaction == "Republic" and bottomFaction == "Separatist" then
    forceTrack.setCustomObject({ image = forceTrackExpansion })
    forceTrack = forceTrack.reload()
  elseif topFaction == "Separatist" and bottomFaction == "Republic" then
    forceTrack.setCustomObject({ image = forceTrackExpansion })
    forceTrack = forceTrack.reload()
    forceTrack.setRotation({ 0.00, 180.00, 0.00 })
  elseif topFaction == "Rebellion" and bottomFaction == "Empire" then
    forceTrack.setCustomObject({ image = forceTrackOriginal })
    forceTrack = forceTrack.reload()
  elseif topFaction == "Empire" and bottomFaction == "Rebellion" then
    forceTrack.setCustomObject({ image = forceTrackOriginal })
    forceTrack = forceTrack.reload()
    forceTrack.setRotation({ 0.00, 180.00, 0.00 })
  end

  -- set turn tracker to first player faction, move into position
  turnTracker.setInvisibleTo({})
  turnTracker.setLock(true)
  turnTracker.interactable = false

  if isAI then
    rotTracker = { 0, 180, 0 }
  end

  turnTracker.setRotation(rotTracker)
  turnTracker.setPosition(posTracker)
  turnTracker.setColorTint(trackerColor)

  -- broadcast GLHF message, include plug for ratings to mod page
  if getObjectbyName("Button Galaxy Deck Original").getGMNotes() == "enabled" then
    broadcastToAll("[" .. Color.fromString("Blue"):toHex() .. "]Original[-] Galaxy Deck has been selected!", "White")
  elseif getObjectbyName("Button Galaxy Deck Random").getGMNotes() == "enabled" then
    broadcastToAll("[" .. Color.fromString("Purple"):toHex() .. "]Random-[-] Galaxy Deck has been selected!", "White")
  elseif getObjectbyName("Button Galaxy Deck Expansion").getGMNotes() == "enabled" then
    broadcastToAll("[" .. Color.fromString("Red"):toHex() .. "]Expansion[-] Galaxy Deck has been selected!", "White")
  end
  Wait.time(function()

    broadcastToAll("If you like this mod, please consider giving a thumbs up to the mod page, and purchasing physical copies of the games!", "White")

  end, 2)
  Wait.time(function()

    broadcastToAll("Good luck, have fun!", "White")

  end, 4)

  -- destroy QR info placards, setup game buttons and backdrop (self)
  if getObjectbyName("Purchase Game Placard") then getObjectbyName("Purchase Game Placard").destruct() end
  if getObjectbyName("Button Galaxy Deck Original") then getObjectbyName("Button Galaxy Deck Original").destruct() end
  if getObjectbyName("Button Galaxy Deck Random") then getObjectbyName("Button Galaxy Deck Random").destruct() end
  if getObjectbyName("Button Galaxy Deck Expansion") then getObjectbyName("Button Galaxy Deck Expansion").destruct() end
  if getObjectbyName("Button Enable Leaders") then getObjectbyName("Button Enable Leaders").destruct() end
  
  
  if isAI then
    setupAIPlayArea(topFaction)
  end
  if getObjectbyName("Button Setup Game") then getObjectbyName("Button Setup Game").destruct() end
end -- end setupGame()


function setupAIPlayArea(faction)
  log("setupAIPlayArea("..faction..") IS RUNNING")

  -- set up solo snap points
  local snapboardMP = getObjectbyName("Top Snapboard MP")
  local bagLeaders = getObjectbyName("Art Asset Top") -- bd droid
  local posSnapboardSolo = { -5.25, -0.25, 14.50 }
  local snapboardSolo = nil
  for _, bagObj in pairs(bagLeaders.getObjects()) do
    if bagObj.name == "Snapboard Solo" then
      snapboardSolo = bagLeaders.takeObject({guid = bagObj.guid})
    end
  end
  Wait.frames(function()
    snapboardSolo.setLock(true)
    snapboardSolo.setRotation({ 0, 180, 0 })
    snapboardSolo.setPosition(posSnapboardSolo)
  end)
  bagLeaders.putObject(snapboardMP)

  -- if not Mandalorian, place leader_board and continue to next Leaders setup func
  if faction ~= "Mandalorian" then
    local rotLeaderBoard = { 0, 180, 0 }
    local posLeaderBoard = { -11.28, 0.10, 17.14 }
    local leaderBoard = nil
    for _, bagObj in pairs(bagLeaders.getObjects()) do
      if bagObj.name == "Leaders Card " .. faction then
        leaderBoard = bagLeaders.takeObject({guid = bagObj.guid})
      end
    end
    if leaderBoard == nil then log("setupAIPlayArea() leaderBoard not found in BD Droid bag!") return end
    
    Wait.frames(function()
      leaderBoard.setLock(true)
      leaderBoard.setRotation(rotLeaderBoard)
      leaderBoard.setPosition(posLeaderBoard)
      leaderBoard.addTag('non_interactable')
      leaderBoard.interactable = false
    end)
    setupAIBoard(faction, _)
  
  -- if Mandalorian, place Leader select panel
  elseif faction == "Mandalorian" then
    local mandalorianLeaderSelectPanel = nil
    local rotPanel = { 0, 180, 0 }
    local posPanel = { 0.00, 0.14, 13.50 }
    for _, bagObj in pairs(bagLeaders.getObjects()) do
      if bagObj.name == "Select Mandalorian Leader Panel" then
        mandalorianLeaderSelectPanel = bagLeaders.takeObject({ guid = bagObj.guid })
      end
    end
    if mandalorianLeaderSelectPanel == nil then log("setupAIPlayArea() mandalorianLeaderSelectPanel not found in BD Droid bag!") return end

    Wait.frames(function()
      mandalorianLeaderSelectPanel.setLock(true)
      mandalorianLeaderSelectPanel.setRotation(rotPanel)
      mandalorianLeaderSelectPanel.setPosition(posPanel)
      mandalorianLeaderSelectPanel.addTag('non_interactable')
      mandalorianLeaderSelectPanel.interactable = false
    end)
  end
end -- end setupAIPlayArea()


function selectBoKatan()
  -- pull leader board, run setupAIBoard("Mandalorian", "Bo-Katan")
  getObjectbyName("Select Mandalorian Leader Panel").destruct()
  local bagLeaders = getObjectbyName("Art Asset Top")
  local rotLeaderBoard = { 0, 180, 0 }
  local posLeaderBoard = { -11.28, 0.10, 17.14 }
  local leaderBoard = nil
  for _, bagObj in pairs(bagLeaders.getObjects()) do
    if bagObj.name == "Leaders Card Mandalorian" then
      leaderBoard = bagLeaders.takeObject({guid = bagObj.guid})
    end
  end
  if leaderBoard == nil then log("setupAIPlayArea() leaderBoard not found in BD Droid bag!") return end
  
  Wait.frames(function()
    leaderBoard.setLock(true)
    leaderBoard.setRotation(rotLeaderBoard)
    leaderBoard.setPosition(posLeaderBoard)
    leaderBoard.addTag('non_interactable')
    leaderBoard.interactable = false
  end)

  setupAIBoard("Mandalorian", "Bo-Katan")
end -- end selectBoKatan()


