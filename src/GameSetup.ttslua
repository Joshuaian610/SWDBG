end -- end enableRandomNeutralDeck()


function initFactionSetupButton(obj)
  local factionName = string.match(obj.getName(), "Button Play (%w+) %w+")
  obj.clearButtons()
  obj.createButton({
    click_function = "setupFaction",
    function_owner = self,
    label          = "",
    color          = {1, 1, 1, .1},
    hover_color    = {1, 1, 1, .3},
    position       = {0, 0.351, 0.00},
    height         = 990,
    width          = 1390,
    tooltip        = "Pressing this button will set your play area up for " .. factionName .. ". This click is instant and permanent!",
    })
end -- end initFactionSetupButton()


function initMandalorianLeaderPanel(obj)
  obj.clearButtons()
  obj.createButton({
    click_function = 'selectBoKatan',
    function_owner = self,
    hover_color    = { 1, 1, 1, 0.5 },
    color          = { 1, 1, 1, 0.2 },
    font_color     = { 1, 1, 1, 255 },
    position       = { 0.00, 0.21, -0.58 },
    rotation       = { 0, 0, 0 },
    width          = 1100,
    height         = 410,
    font_size      = 200,
    tooltip        = "Click to play against AI Bo-Katan."
  })
  obj.createButton({
    click_function = 'selectTheMandalorian',
    function_owner = self,
    hover_color    = { 1, 1, 1, 0.5 },
    color          = { 1, 1, 1, 0.2 },
    font_color     = { 1, 1, 1, 255 },
    position       = { 0.00, 0.21, 0.435 },
    rotation       = { 0, 0, 0 },
    width          = 1100,
    height         = 525,
    font_size      = 200,
    tooltip        = "Click to play against AI Mandalorian and Grogu.",
  })
end -- end initMandalorianLeaderPanel()


function initLeaders(obj, _, _)
  -- need a function to init button onLoad/rewinds
  obj.clearButtons()

  if obj.getGMNotes() == "enabled" then
    obj.createButton({
      click_function = "toggleLeaders",
      function_owner = self,
      label          = '✔',
      color          = { 1, 1, 1, .1 },
      hover_color    = { 1, 1, 1, .3 },
      position       = { 0, 0.21, 0 },
      rotation       = { 0, 0, 0 },
      width          = 1300,
      height         = 1000,
      font_size      = 2500,
      font_color     = { 1, 1, 1, 255 },
      tooltip        = "This button, if unchecked, will disable the setup of the top player area for the Leaders AI bot, and enable the setup of the top player area for Multiplayer.",
    })

  else
    obj.createButton({
      click_function = "toggleLeaders",
      function_owner = self,
      label          = '',
      color          = { 1, 1, 1, .1 },
      hover_color    = { 1, 1, 1, .3 },
      position       = { 0, 0.21, 0 },
      rotation       = { 0, 0, 0 },
      width          = 1300,
      height         = 1000,
      tooltip        = "This button, if checked, will enable the setup of the top player area for the Leaders AI bot, and disable the setup of the top player area for Multiplayer.",
    })
  end

end -- end initLeaders()

function toggleLeaders(obj, _, _)  

  obj.clearButtons()

  if obj.getGMNotes() == "enabled" then
    obj.setGMNotes("disabled")
  elseif obj.getGMNotes() == "disabled" then
    obj.setGMNotes("enabled")
  end

  if obj.getGMNotes() == "enabled" then
    obj.createButton({
      click_function = "toggleLeaders",
      function_owner = self,
      label          = '✔',
      color          = { 1, 1, 1, .1 },
      hover_color    = { 1, 1, 1, .3 },
      position       = { 0, 0.21, 0 },
      rotation       = { 0, 0, 0 },
      width          = 1300,
      height         = 1000,
      font_size      = 2500,
      font_color     = { 1, 1, 1, 255 },
      tooltip        = "This button, if unchecked, will disable the setup of the top player area for the Leaders AI bot, and enable the setup of the top player area for Multiplayer.",
    })

  else
    obj.createButton({
      click_function = "toggleLeaders",
      function_owner = self,
      label          = '',
      color          = { 1, 1, 1, .1 },
      hover_color    = { 1, 1, 1, .3 },
      position       = { 0, 0.21, 0 },
      rotation       = { 0, 0, 0 },
      width          = 1300,
      height         = 1000,
      tooltip        = "This button, if checked, will enable the setup of the top player area for the Leaders AI bot, and disable the setup of the top player area for Multiplayer.",
    })
  end
end -- end toggleLeaders()



