end -- end selectTheMandalorian()


function setupAIBoard(faction, factionLeader)  
  
  -- pull troopers from starter deck, place to start
  local deckStarter = getObjectbyName(faction .. " Deck")
  local rotTrooper1 = { 0.00, 180.00, 0.00 }
  local posTrooper1 = { 2.77, 0.15, 20.39 } -- muster area, faceup
  local rotTrooper2 = { 0.00, 180.00, 180.00 }
  local posTrooper2 = { -1.88, 0.25, 20.39 } -- muster area, facedown  
  local trooperNames = {
    ["Empire"]       = "Stormtrooper",
    ["Rebellion"]    = "Rebel Trooper",
    ["Separatist"]   = "B1 Battle Droid",
    ["Republic"]     = "Clone Trooper",
    ["Mandalorian"]  = "Mandalorian Soldier"
  }
  local trooperName = trooperNames[faction]

  local trooper1 = nil
  for _, deckObj in pairs(deckStarter.getObjects()) do
    if deckObj.name == trooperName then
      trooper1 = deckStarter.takeObject({ guid = deckObj.guid })
      break
    end
  end
  Wait.frames(function()
    if trooper1 then
      trooper1.setRotation(rotTrooper1)
      trooper1.setPositionSmooth(posTrooper1, false, true)
    end
  end)

  local trooper2 = nil
  for _, deckObj in pairs(deckStarter.getObjects()) do
    if deckObj.name == trooperName then
      trooper2 = deckStarter.takeObject({ guid = deckObj.guid })
      break
    end
  end
  Wait.frames(function()
    if trooper2 then
      trooper2.setRotation(rotTrooper2)
      trooper2.setPositionSmooth(posTrooper2, false, true)
    end
  end)
  
  -- pull shuttles, drop into pile
  local shuttleName = (faction == "Empire" and "Imperial Shuttle") or (faction == "Rebellion" and "Alliance Shuttle") or faction .. " Shuttle"
  local rotShuttles = { 0.00, 180.00, 0.00 }
  local posShuttles = { -20.78, 0.25, 13.89 }
  
  for i = 1, 3 do
    local shuttle = nil
    for _, deckObj in pairs(deckStarter.getObjects()) do
      if deckObj.name == shuttleName then
        shuttle = deckStarter.takeObject({ guid = deckObj.guid })
        break
      end
    end
    Wait.frames(function()
      shuttle.setRotation(rotShuttles)
      shuttle.setPosition(posShuttles, false, true)
    end)
  end

  -- wait 1 sec for Galaxy deck to be created, create reserves deck  
  -- bottom to top - shuttle X3, maybe companion, agent, shuttle
  -- then, place leader

  -- bottom shuttles
  Wait.time(function()
    
    local rotReserves = { 0.00, 180.00, 180.00 }
    local posReserves = {
      { -20.78, 0.25, 20.39 },
      { -20.78, 0.35, 20.39 },
      { -20.78, 0.45, 20.39 },
      { -20.78, 0.55, 20.39 },
      { -20.78, 0.65, 20.39 },
      { -20.78, 0.75, 20.39 },
    }
    
    local deckGalaxy = getGalaxyDeck()

    -- shuttles x3
    for i = 1, 3 do
      local shuttle = nil
      for _, deckObj in pairs(deckStarter.getObjects()) do
        if deckObj.name:find("Shuttle") then
          shuttle = deckStarter.takeObject({ guid = deckObj.guid })
          break
        end
      end      
      Wait.frames(function()
        shuttle.setRotation(rotReserves)
        shuttle.setPosition(posReserves[i])
      end)
    end

    -- companion
    if faction == "Separatist" or faction == "Republic" or factionLeader == "The Mandalorian" then      
      local companionName = (faction == "Separatist" and "General Grievous") or (faction == "Republic" and "Ahsoka Tano") or "Grogu"
      local companion = nil
      for _, deckObj in pairs(deckGalaxy.getObjects()) do
        if deckObj.name == companionName then
          companion = deckGalaxy.takeObject({ guid = deckObj.guid })
          break
        end
      end
      if companion == nil then log("setupAIBoard() companion not found") return end
      Wait.frames(function()
        companion.setRotation(rotReserves)
        companion.setPosition(posReserves[4])
      end)
    end

    -- agent
    local agentNames = {
      ["Empire"]       = "Inquisitor",
      ["Rebellion"]    = "Temple Guardian",
      ["Separatist"]   = "Dark Side Agent",
      ["Republic"]     = "Jedi Knight",
      ["Mandalorian"]  = "Child of the Watch"
    }
    local agentName = agentNames[faction]
    local agent = nil
    for _, deckObj in pairs(deckStarter.getObjects()) do
      if deckObj.name == agentName then
        agent = deckStarter.takeObject({ guid = deckObj.guid })
        break
      end
    end
    if agent == nil then log("setupAIBoard() agent not found") return end
    Wait.frames(function()
      agent.setRotation(rotReserves)
      agent.setPosition(posReserves[5])
    end)

    -- top shuttle (need to wait just a bit to allow last card to be found, and for the object to not be a deck)
    Wait.time(function()

      local lastShuttle = nil
      local zoneDeck = getObjectbyName("Zone Deck Top")
      for _, zoneObj in pairs( zoneDeck.getObjects() ) do
        if zoneObj.type == "Card" then
          lastShuttle = zoneObj
        end
      end
      if lastShuttle == nil then log("setupAIBoard() lastShuttle not found") return end
      Wait.frames(function()
        lastShuttle.setRotation(rotReserves)
        lastShuttle.setPosition(posReserves[6])
      end)
    
    end, .5)

    -- Wait 2 sec, check for created Reserves & Shuttles decks & name them
    Wait.time(function()

      local zoneReserves = getObjectbyName("Zone Leaders Reserves")
      local zoneShuttles = getObjectbyName("Zone Leaders Shuttles")
      for _, zoneObj in pairs(zoneReserves.getObjects()) do
        if zoneObj.type == "Deck" then zoneObj.setName(faction .. " Reserves") end
      end
      for _, zoneObj in pairs(zoneShuttles.getObjects()) do
        if zoneObj.type == "Deck" then zoneObj.setName(faction .. " Shuttles") end
      end
    
    end, 2)

    -- place leader    
    local leaderNames = {
      ["Empire"]     = "Darth Vader",
      ["Separatist"] = "Asajj Ventress",
      ["Rebellion"]  = "Luke Skywalker",
      ["Republic"]   = "Anakin Skywalker",
    }
    local leaderName = nil
    if faction ~= "Mandalorian" then
      leaderName = leaderNames[faction]
    else
      leaderName = factionLeader
    end
    local leader = nil
    deckGalaxy = getGalaxyDeck()
    for _, deckObj in pairs(deckGalaxy.getObjects()) do
      if deckObj.name == leaderName then
        leader = deckGalaxy.takeObject({guid = deckObj.guid})
      end
    end
    if leader == nil then log("setupAIBoard() leader not found") return end
    local rotLeader = { 0.00, 180.00, 0.00 }
    local posLeader = { -7.70, 0.60, 16.67 }
    Wait.frames(function()
      leader.setRotation(rotLeader)
      leader.setPositionSmooth(posLeader, false, true)
    end)

  end, 1)

  -- base setup
  local starterBaseNames = {
    ["Empire"]      = "Lothal",
    ["Separatist"]  = "Xorrn",
    ["Rebellion"]   = "Dantooine",
    ["Republic"]    = "Rishi",
    ["Mandalorian"] = "Concord Dawn",
  }
  local starterBaseName = starterBaseNames[faction]
  local rotStarterBase = { 0.00, 180.00, 0.00 }
  local posStarterBase = { -14.09, 0.63, 15.88 }

  -- get, position, lock starter base  
  local starterBase = getObjectbyName(starterBaseName)
  if not starterBase then log("setupAIBoard() starterBase not found") return end

  starterBase.setLock(true)
  starterBase.setRotation( rotStarterBase)
  starterBase.setPositionSmooth(posStarterBase, false, true)

  -- shuffle base deck. draw 2, place (should form deck on each other)
  local baseDeck = getObjectbyName(faction .. " Bases")
  local rotBases = { 0.00, 180.00, 180.00 }
  local posBases = { -14.09, 0.58, 15.90  }
  baseDeck.shuffle()
  local base3 = baseDeck.takeObject()
  local base2 = baseDeck.takeObject()
  Wait.frames(function()
    base3.setRotation(rotBases)
    base3.setPositionSmooth(posBases, false, true)
    posBases.y = 0.60
    base2.setRotation(rotBases)
    base2.setPositionSmooth(posBases, false, true)
  end)

  local bagLeaders = getObjectbyName("Art Asset Top")
  bagLeaders.putObject(baseDeck)
  -- name base deck
  Wait.time(function()

    local baseZoneAI = getObjectbyName("Zone Leaders Bases")
    for _, zoneObj in pairs(baseZoneAI.getObjects()) do
      if zoneObj.type == "Deck" then zoneObj.setName("AI " .. faction .. " Bases") end
    end
    
  end, 1)

  -- position rules
  local rotRules = { 60.00, 180.00, 0.00 }
  local posRules = faction ~= "Mandalorian" and {
    { -8.00, 5.85, 28.03 },
    { 8.00, 5.85, 28.03 },
  } or {
    { -16.00, 5.85, 28.03 },
    { 0.00, 5.85, 28.03 },
  }
  local posMandalorianRules = { 16.00, 5.85, 28.03 }
  -- will always need to pull rules1 & rules2, mandalorian will pull CW rules1, rules2, and also mandalorian rules
  for i = 1, 2 do
    local ruleSheetName = (faction == "Empire" or faction == "Rebellion") and "Leaders Rules Original p" .. tostring(i) or "Leaders Rules Clone Wars p" .. tostring(i)
    local ruleSheet = nil
    for _, bagObj in pairs(bagLeaders.getObjects()) do
      if bagObj.name == ruleSheetName then
        ruleSheet = bagLeaders.takeObject({ guid = bagObj.guid })
        break
      end
    end
    Wait.frames(function()
      if ruleSheet then
        ruleSheet.setLock(true)
        ruleSheet.setRotation(rotRules)
        ruleSheet.setPosition(posRules[i])
      end
    end)
  end
  local ruleSheetMandalorian = nil
  if faction == "Mandalorian" then
    for _, bagObject in pairs(bagLeaders.getObjects()) do
      if bagObject.name == "Leaders Rules Mandalorian" then
        ruleSheetMandalorian = bagLeaders.takeObject({ guid = bagObject.guid })
        break
      end
    end
  end
  if ruleSheetMandalorian ~= nil then
    ruleSheetMandalorian.setLock(true)
    ruleSheetMandalorian.setRotation(rotRules)
    ruleSheetMandalorian.setPosition(posMandalorianRules)
  end

  -- flip, move, or delete required top UI objects for solo play

  -- rotate board resource counter
  getObjectbyName("Resource Counter Board Top").setRotation({0.00, 180.00, 0.00})

  -- -- drop, flip player area resource counter (hide object, button)
  -- manipulate_objects[2].setRotation({0.00, 0.00, 180.00})
  getObjectbyName("Resource Counter Top").setRotation({ 0.00, 180.00, 180.00 })

  -- rotate end turn button
  getObjectbyName("Button End Turn Top").setRotation({ 0.00, 180.00, 0.00 })

  -- -- rotate force with me button
  local buttonForceAI = getObjectbyName("Button Force Top")
  buttonForceAI.setRotation({ 0.00, 180.00, 0.00 })

  local forceButtonImages = {
    ["Empire"]      = "https://steamusercontent-a.akamaihd.net/ugc/2423592667296865269/B758EF2809731A8FE9E76FCF295FB2E00EEC95BA/",
    ["Separatist"]  = "https://steamusercontent-a.akamaihd.net/ugc/2423592667296864303/52D7C7B1ACFB4D767CE5334D661D85FEB6401EAC/",
    ["Rebellion"]   = "https://steamusercontent-a.akamaihd.net/ugc/2423592667296866592/E1C0458973E5499BA1D23BC561AC3ECB4A930E33/",
    ["Republic"]    = "https://steamusercontent-a.akamaihd.net/ugc/2423592667296866003/3EE1657DEAA4B1B54F832270AB029EB182B3A41B/",
    ["Mandalorian"] = "https://steamusercontent-a.akamaihd.net/ugc/16100705095393989779/5CAD1063A1057442326E469C6480F77A510B6BC3/",
  }
  local forceButtonImage = forceButtonImages[faction]
  buttonForceAI.setCustomObject({image = forceButtonImage})
  buttonForceAI.reload()

  -- rotate, position base damage counter
  local damageCounterAI = getObjectbyName("Damage Counter " .. faction)
  local rotDamageCounterAI = { 0.00, 180.00, 0.00 }
  local posDamageCounterAI = { -20.83, 0.10, 7.69 }
  damageCounterAI.setRotation(rotDamageCounterAI)
  damageCounterAI.setPosition(posDamageCounterAI)
  
  -- rotate victory pad
  getObjectbyName("Pad Victory Pile Top").setRotation({0.00, 180.00, 0.00})

  -- rotate, tint purchase buttons
  local _, topColor = getPlayerColors()
  local aiPurchaseButtons = {
    getObjectbyNameAndNotes("Button Purchase", "8"),
    getObjectbyNameAndNotes("Button Purchase", "9"),
    getObjectbyNameAndNotes("Button Purchase", "10"),
    getObjectbyNameAndNotes("Button Purchase", "11"),
    getObjectbyNameAndNotes("Button Purchase", "12"),
    getObjectbyNameAndNotes("Button Purchase", "13"),
    getObjectbyNameAndNotes("Button Purchase", "14"),
  }
  local rotAIPurchaseButtons = { 0.00, 180.00, 0.00 }
  for i = 1, 7 do
    aiPurchaseButtons[i].setRotation(rotAIPurchaseButtons)
    aiPurchaseButtons[i].setColorTint(topColor)
  end

  -- destroy no longer required UI objects
  local destroyObjs = {
    getObjectbyName("Pad Deck " .. faction),
    getObjectbyName("Pad Discard " .. faction),
    getObjectbyName("Pad Bases " .. faction),
    getObjectbyName("Button Discard " .. faction),
    getObjectbyNameAndNotes("Button Discard", "7"),
    getObjectbyNameAndNotes("Button Discard", "8"),
    getObjectbyNameAndNotes("Button Discard", "9"),
    getObjectbyNameAndNotes("Button Discard", "10"),
    getObjectbyNameAndNotes("Button Discard", "11"),
    getObjectbyNameAndNotes("Button Discard", "12"),
    getObjectbyName("Counter Bag Top"),
  }

  Wait.time(function()

    for i = 1, 11 do
      destroyObjs[i].destruct()
    end

  end, 1.5)

    -- pull leader board marker cubes
    local cubeProgress = nil
    for _, bagObj in pairs(bagLeaders.getObjects()) do
      if bagObj.name == "AI Progress Tracker" and bagObj.gm_notes == topColor then
        cubeProgress = bagLeaders.takeObject({ guid = bagObj.guid })
        break
      end
    end
    if cubeProgress ~= nil then
      local rotCubeProgress = { 0.00, 180.00, 0.00 }
      local posCubeProgress = { -17.76, 0.85, 21.88 }
      cubeProgress.setRotation(rotCubeProgress)
      cubeProgress.setPositionSmooth(posCubeProgress, false, true)
      cubeProgress.highlightOn(topColor)
    end
    local cubeResources = nil
    for _, bagObj in pairs(bagLeaders.getObjects()) do
      if bagObj.name == "AI Resource Tracker" then
        cubeResources = bagLeaders.takeObject({ guid = bagObj.guid })
        break
      end
    end
    if cubeResources ~= nil then
      local rotCubeResources = { 0.00, 180.00, 0.00 }
      local posCubeResources = { -15.74, 0.74, 12.85 }
      cubeResources.setRotation(rotCubeResources)
      cubeResources.setPositionSmooth(posCubeResources, false, true)
      cubeResources.highlightOn("Yellow")
      cubeResources.setLock(true)
    end

    -- tint leaderboard
    getObjectbyName("Leaders Card " .. faction).setColorTint(topColor)

    -- place muster pad, reimage, tint
    local musterPadName = "Facedown Muster Pad " .. faction
    local musterPad = nil
    for _, bagObj in pairs(bagLeaders.getObjects()) do
      if bagObj.name == musterPadName then
        musterPad = bagLeaders.takeObject({ guid = bagObj.guid })
      end
    end
    
    Wait.frames(function()
      if musterPad then
        local rotMusterPad = { 0.00, 180.00, 180.00 }
        local posMusterPad = { -1.88, 0.10, 20.39 }
        musterPad.setLock(true)
        musterPad.interactable = false
        musterPad.setRotation(rotMusterPad)
        musterPad.setPosition(posMusterPad)
        musterPad.setColorTint(topColor)
      end
    end)
    
    -- wait 3 seconds, unlock starter base
    Wait.time(function() starterBase.setLock(false) end, 3)
    
end -- end setupAIBoard()
