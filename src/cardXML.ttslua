  -- first check if Jar Jar and is in zone row
  local cardInZoneRow = false
  for _, zone in pairs(card.getZones()) do
    if zone.getName():find("Zone Row") then
      cardInZoneRow = true
    end
  end
  if card.getName() == "Jar Jar Binks" and cardInZoneRow and
  (not card.hasTag('bottom_owner') and not card.hasTag('top_owner')) then
    table.insert(finalXML, abilityButtonXML["Ability Large White"])
    table.insert(finalImg, abilityButtonImg["Ability Large White"])
  end
  
  if buttonColor then

    -- Insert ability buttons
    if card.hasTag("ability_button_large") and (card.hasTag("bottom_owner") or card.hasTag("top_owner")) then -- extra check is to not fire jar jar
      table.insert(finalXML, abilityButtonXML["Ability Large " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Ability Large " .. buttonColor])
    end
    
    if card.hasTag("exile_button") then
      table.insert(finalXML, abilityButtonXML["Exile " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Exile " .. buttonColor])
    end

    if card.hasTag("draw_button") then
      table.insert(finalXML, abilityButtonXML["Draw " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Draw " .. buttonColor])
    end

    if card.hasTag("discard_button") then
      table.insert(finalXML, abilityButtonXML["Discard " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Discard " .. buttonColor])
    end

    if card.hasTag("reveal_button") then
      table.insert(finalXML, abilityButtonXML["Reveal " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Reveal " .. buttonColor])
    end

    if card.hasTag("attack_button") then
      table.insert(finalXML, abilityButtonXML["Attack " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Attack " .. buttonColor])
    end

    if card.hasTag("repair_button_small") then
      table.insert(finalXML, abilityButtonXML["Repair Small " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Repair Small " .. buttonColor])
    end

    if card.hasTag("repair_button_large") then
      table.insert(finalXML, abilityButtonXML["Repair Large " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Repair Large " .. buttonColor])
    end

    if card.hasTag("ability_button_sec") and card.hasTag('unit') then
      table.insert(finalXML, abilityButtonXML["Ability Small Gold"])
      table.insert(finalImg, abilityButtonImg["Ability Small Gold"])
    end

    if card.hasTag("ability_button_sec") and card.hasTag('ship') then
      table.insert(finalXML, abilityButtonXML["Ability Large Gold"])
      table.insert(finalImg, abilityButtonImg["Ability Large Gold"])
    end
    
    if card.hasTag("add_force_button") then
      table.insert(finalXML, abilityButtonXML["Force " .. buttonColor])
      table.insert(finalImg, abilityButtonImg["Force " .. buttonColor])
    end

    if card.hasTag("requires_cancel") then
      table.insert(finalXML, abilityButtonXML["Ability Cancel"])
      table.insert(finalImg, abilityButtonImg["Ability Cancel"])
    end

    -- log("\nfinalImg:")
    -- log(finalImg)
    -- log("\nfinalXML:")
    -- log(finalXML)

    -- Apply XML & assets
    if #finalXML > 0 and #finalImg > 0 then
      card.UI.setCustomAssets(finalImg)
      card.UI.setXmlTable(finalXML)

      -- Show all panels to trigger Grow animation
      Wait.time(function()
        for _, panel in ipairs(finalXML) do
          if panel.attributes.id ~= "ability_button_cancel" then
            card.UI.show(panel.attributes.id)
          end
        end
      end, 0.5)
    end
  end
end -- end initCardXML()


