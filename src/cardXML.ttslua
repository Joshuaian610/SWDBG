-- this require page will contain the XML data and functions to manage the XML card buttons

function initCardXML(card)

  log("initCardXML(" .. card.getName() .. ") IS RUNNING")

  local isBottom = card.hasTag("bottom_owner") and true or false
  local bottomColor, topColor = getPlayerColors()
  local buttonColor = isBottom and bottomColor or topColor

  local cardGUID = card.getGUID()
  local finalXML = {}
  local finalImg = {}
  local rotPri = card.hasTag('unit') and "0 0 180" or "0 0 90"
  -- default posPri, buttonWidth assumes multiple button config
  local posPri = card.hasTag('unit') and "63 175 -20" or "133 -75 -30"
  local buttonWidth = nil
  local rotSec = card.hasTag('unit') and "0 0 180" or "0 0 90"
  local posSec = card.hasTag('unit') and "-23 175 -30" or "133 75 -30"
  local rotForce = "0 0 180"
  local posForce = "40 -43 -30"
  local clickFunc = "Global/buttonActionXML(" .. cardGUID .. ")"
  local clickFuncSec = "Global/buttonActionSecXML(" .. cardGUID .. ")"
  local clickFuncForce = "Global/addUnitForce(" .. cardGUID .. ")"

  if card.hasTag('XML1Button') then
    posPri = card.hasTag('unit') and "0 175 -20" or "133 0 -30"
    buttonWidth = 150
  end
  
  if card.getName() == "Zam Wesell" or card.getName() == "Lobot" or
  card.getName() == "Inquisitor" or card.getName() == "Child of the Watch" or card.getName() == "Temple Guardian" then
    buttonWidth = 85
    posForce = "-87 175 -30"

  elseif card.getName() == "Landing Craft" then
    buttonWidth = 85
    posPri = "45 175 -30"
    posSec = "-45 175 -30"
    
  elseif card.getName() == "Nebulon-B Frigate" then
    buttonWidth = 150
    posPri = "133 -75 -30"
    posSec = "133 75 -30"
  end

  local abilityButtonXML = {

    -- LARGE ABILITY BUTTONS
    ["Ability Large Blue"] = {
      tag                 = "Panel",
      attributes          = {
        id                = "ability_button_blue_large",
        active            = "false",
        height            = "40",
        width             = buttonWidth,
        position          = posPri,
        rotation          = rotPri,
        showAnimation     = "Grow",
        hideAnimation     = "Shrink",
        animationDuration = ".25"
      },
      children            = {
        {
          tag             = "Button",
          attributes      = {
            onClick       = clickFunc,
            image         = "Ability Large Blue"
          }
        }
      }
    },

    ["Ability Large Gold"]              = {
      tag                 = "Panel",
      attributes          = {
        id                = "ability_button_gold_large",
        active            = "false",
        height            = "40",
        width             = buttonWidth,
        position          = posSec,
        rotation          = rotSec,
        showAnimation     = "Grow",
        hideAnimation     = "Shrink",
        animationDuration = ".25"
      },
      children            = {
        {
          tag             = "Button",
          attributes      = {
            onClick       = clickFuncSec,
            image         = "Ability Large Gold"
          }
        }
      }
    },

    ["Ability Large Orange"]            = {
      tag                 = "Panel",
      attributes          = {
        id                = "ability_button_orange_large",
        active            = "false",
        height            = "40",
        width             = buttonWidth,
        position          = posPri,
        rotation          = rotPri,
        showAnimation     = "Grow",
        hideAnimation     = "Shrink",
        animationDuration = ".25"
      },
      children            = {
        {
          tag             = "Button",
          attributes      = {
            onClick       = clickFunc,
            image         = "Ability Large Orange"
          }
        }
      }
    },

    ["Ability Large Purple"]            = {
